# Przechowuje zależności (ważą setki MB, instaluje się je przez npm install)
node_modules/

# Wynik budowania aplikacji (produkcyjny kod, który generuje się automatycznie)
dist/
dist-ssr/
build/

# Pliki środowiskowe (mogą zawierać klucze API, jeśli jakieś dodasz w przyszłości)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logi błędów
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Pliki systemowe i edytora
.vscode/
.idea/
.DS_Store
Thumbs.db

# Pliki TypeScript i Eslint (jeśli są generowane automatycznie jako cache)
*.tsbuildinfo
.eslintcache
